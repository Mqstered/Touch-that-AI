# Copy this file to .env and fill in your Supabase project values.
# Find these in: Supabase Dashboard → Project Settings → API
#
# SECURITY RULES:
#   - Never commit .env to git (it is in .gitignore)
#   - EXPO_PUBLIC_* variables are bundled into the app and visible to users.
#     The ANON key is intentionally public — it has limited row-level permissions.
#   - NEVER put your service_role key here. It belongs only in server-side code.

EXPO_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
